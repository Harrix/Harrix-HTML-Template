{
  "name": "harrix-html-template",
  "version": "2.0.0",
  "description": "HTML template",
  "main": "src/js/index.js",
  "scripts": {
    "dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "start": "webpack serve --no-client-overlay-warnings",
    "build": "npm run format && webpack --mode production && prettier --ignore-path .prettierignore --write \"dist/**/*.html\" && node scripts/sync-dist-history.mjs",
    "build:dist-history": "npm run build",
    "sync:dist-history": "node scripts/sync-dist-history.mjs",
    "check": "eslint . --cache --cache-location node_modules/.cache/eslint",
    "check:fix": "eslint . --fix --cache --cache-location node_modules/.cache/eslint",
    "check:css": "stylelint \"src/scss/**/*.scss\"",
    "format": "prettier --write \"src/**/*.{js,scss,html}\" \"*.{js,mjs,json,md}\" && prettier --ignore-path .prettierignore --write \"dist/**/*.html\"",
    "format:check": "prettier --check \"src/**/*.{js,scss,html}\" \"*.{js,mjs,json,md}\" && prettier --ignore-path .prettierignore --check \"dist/**/*.html\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Harrix/Harrix-HTML-Template.git"
  },
  "author": "Sergienko Anton <sergienkoanton@mail.ru> (https://harrix.org)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Harrix/Harrix-HTML-Template/issues"
  },
  "homepage": "https://github.com/Harrix/Harrix-HTML-Template#readme",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": [
    "*.scss",
    "*.css"
  ],
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "bulma": "^1.0.4",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.44",
    "lightgallery": "^2.9.0",
    "mermaid": "^11.0.0",
    "plotly.js-dist-min": "^3.4.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "eslint": "^10.1.0",
    "eta": "^4.5.1",
    "globals": "^17.4.0",
    "html-webpack-plugin": "^5.6.6",
    "mini-css-extract-plugin": "^2.10.2",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "stylelint": "^16.21.1",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-order": "^7.0.0",
    "terser-webpack-plugin": "^5.4.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
